    "dotenv": "^16.6.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.18",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jest-environment-node": "^29.7.0",
    "postcss": "^8.5.6",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "undici": "^7.16.0"
  }
