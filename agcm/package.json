    "lucide-react": "^0.548.0",
    "next": "15.5.18",
    "next-auth": "5.0.0-beta.30",
    "next-themes": "^0.4.6",
    "qrcode.react": "^4.2.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.65.0",
    "recharts": "^3.8.1",
    "resend": "^6.4.2",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
