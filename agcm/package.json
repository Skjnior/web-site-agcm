{
  "name": "agcm-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "rm -rf .next && next dev",
    "dev:turbo": "next dev --turbopack",
    "build": "prisma generate && prisma migrate deploy && next build",
    "build:turbo": "prisma generate && next build --turbopack",
    "start": "next start",
    "lint": "eslint",
    "db:reset-bureau-passwords": "tsx prisma/reset-bureau-passwords.ts",
    "db:seed-bureau-prod": "tsx prisma/seed-bureau-prod.ts",
    "db:import-registre": "tsx prisma/import-registre-cotisations.ts",
    "db:trim-demo-members": "tsx prisma/trim-demo-members.ts",
    "db:trim-to-registre-bureau": "tsx prisma/trim-to-registre-pdf-and-bureau.ts",
    "db:trim-all-public": "tsx prisma/trim-all-public-content.ts",
    "db:diag-president": "tsx prisma/diag-president.ts",
    "db:cleanup-mandats-postes": "tsx prisma/cleanup-mandats-postes.ts",
    "db:seed-partners": "tsx prisma/seed-partners.ts",
    "db:trim": "tsx prisma/trim-public-content.ts",
    "db:trim:dry": "DRY_RUN=1 tsx prisma/trim-public-content.ts",
    "seed": "echo \"⚠️  Le seed complet efface la base. Utilisez: npm run seed:fresh (dev uniquement) ou npm run db:trim pour alléger le contenu.\" && exit 1",
    "seed:fresh": "tsx prisma/seed.ts",
    "seed:legacy-600": "tsx prisma/seed.legacy-600-bulk.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@emailjs/nodejs": "^5.0.2",
