# Copier vers .env ou .env.local et remplir les valeurs (ne pas commiter les vrais fichiers)

# Base PostgreSQL (local ou hébergée)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/agcm?sslmode=prefer"
agcm_db_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/agcm?sslmode=prefer"

# NextAuth — générer un secret : openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
