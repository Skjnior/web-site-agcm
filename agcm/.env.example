# Copier vers .env ou .env.local et remplir les valeurs (ne pas commiter les vrais fichiers)

# Base PostgreSQL (local ou hébergée)
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/agcm?sslmode=prefer"
agcm_db_DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/agcm?sslmode=prefer"

# NextAuth — générer un secret : openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Optionnel — Vercel Blob pour les images (upload). Si absent, les fichiers vont dans public/uploads/images/ (OK en local ; sur Vercel sans Blob, préférez ce token).
# Vercel → Projet → Storage → Blob → .env
# BLOB_READ_WRITE_TOKEN=

# E-mail (notifications formulaires publics : EmailJS + secours Resend)
# EmailJS — service Gmail + templates (même valeurs que le dashboard ; surcharge possibles)
EMAILJS_SERVICE_ID=service_w0zlpfb
EMAILJS_TEMPLATE_CONTACT=template_m6wz0tn
EMAILJS_TEMPLATE_ADHESION=template_b1lpr33
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
# Si pas de NEXT_PUBLIC_SITE_URL / NEXTAUTH_URL : URL absolue du logo
# EMAILJS_LOGO_URL=https://votredomaine.fr/Image/logo.jpg
NEXT_PUBLIC_SITE_URL=http://localhost:3000
ADMIN_EMAIL=contact@agcm-guinee.org

# Comptes bureau (npm run db:reset-bureau-passwords) — ne pas commiter la vraie valeur
# BUREAU_PASSWORD=

# Afficher les requêtes SQL Prisma dans la console en dev (sinon seulement error/warn)
# PRISMA_LOG_QUERIES=1

# Secours si EmailJS échoue
# RESEND_API_KEY=
# EMAIL_FROM=AGCM <noreply@example.com>
