generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                           String               @id @default(cuid())
  email                        String               @unique
  passwordHash                 String               @map("password_hash")
  roleSysteme                  RoleSysteme          @default(MEMBER) @map("role_systeme")
  isActive                     Boolean              @default(true) @map("is_active")
  lastLogin                    DateTime?            @map("last_login")
  createdAt                    DateTime             @default(now()) @map("created_at")
  updatedAt                    DateTime             @updatedAt @map("updated_at")
  deletedAt                    DateTime?            @map("deleted_at")
  auditLogs                    AuditLog[]
  bureauMessages               BureauMessage[]
  comments                     Comment[]
  approvedContents             Content[]            @relation("ContentApprovedBy")
  demandesAdhesionProcessed    DemandeAdhesion[]    @relation("DemandeAdhesionProcessedBy")
  demandesPartenariatProcessed DemandePartenariat[] @relation("DemandePartenariatProcessedBy")
  member                       Member?
  notifications                Notification[]
  pageViews                    PageView[]
  dmPeerForBureauMessages      BureauMessage[]      @relation("BureauMessageDmPeer")
  bureauMessagesDeletedAsActor BureauMessage[]      @relation("BureauMessageDeletedBy")
  registreCotisationsUpdated   MemberRegistreCotisation[] @relation("RegistreCotisationUpdatedBy")

  @@map("users")
}

model Notification {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  type       String
  message    String
  entityType String?  @map("entity_type")
  entityId   String?  @map("entity_id")
  isRead     Boolean  @default(false) @map("is_read")
  createdAt  DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

model Member {
  id            String             @id @default(cuid())
  /// Compte de connexion : null = adhérent inscrit en base sans accès au site (gestion par le bureau)
  userId        String?            @unique @map("user_id")
  /// Email de contact pour les adhérents sans compte ; les membres avec `userId` utilisent en priorité `user.email`
  email         String?            @unique @map("email")
  prenom        String
  nom           String
  telephone     String?
  ville         String?
  pays          String?
  photoUrl      String?            @map("photo_url")
  bio           String?
  statutMembre  StatutMembre       @default(ACTIF) @map("statut_membre")
  dateAdhesion  DateTime           @default(now()) @map("date_adhesion")
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  genre         GenreMembre?       @map("genre")
  dateNaissance DateTime?          @map("date_naissance") @db.Date
  profession    String?
  adresse       String?
  affectations              AffectationPoste[]
  user                      User?                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  registreCotisations       MemberRegistreCotisation[]

  @@index([nom, prenom])
  @@map("members")
}

/// Registre type Excel/PDF « situation cotisation au … » + absences aux réunions
model MemberRegistreCotisation {
  id                String   @id @default(cuid())
  memberId          String   @map("member_id")
  dateReference     DateTime @map("date_reference") @db.Date
  situationText     String   @default("") @map("situation_text") @db.Text
  absencesText      String?  @map("absences_text") @db.Text
  updatedByUserId   String?  @map("updated_by_user_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  member            Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  updatedByUser     User?    @relation("RegistreCotisationUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@unique([memberId, dateReference])
  @@index([dateReference])
  @@map("member_registre_cotisations")
}

model Mandat {
  id             String             @id @default(cuid())
  titre          String
  dateDebut      DateTime           @map("date_debut")
  dateFin        DateTime           @map("date_fin")
  statut         StatutMandat       @default(ACTIF)
  pvDocumentUrl  String?            @map("pv_document_url")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  affectations   AffectationPoste[]
  bureauMessages BureauMessage[]
  contents       Content[]
  events         Event[]
  projets        Projet[]

  @@index([statut])
  @@map("mandats")
}

model Poste {
  id                   String             @id @default(cuid())
  nom                  String             @unique
  description          String?
  estBureau            Boolean            @default(true) @map("est_bureau")
  estActif             Boolean            @default(true) @map("est_actif")
  createdAt            DateTime           @default(now()) @map("created_at")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  affectations         AffectationPoste[]
  authoredContents     Content[]          @relation("ContentAuteurPoste")
  donationsHandled     DonationIntent[]   @relation("DonationHandledByPoste")
  eventsCreated        Event[]            @relation("EventCreatedByPoste")
  contactsAssigned     MessageContact[]   @relation("ContactAssignedToPoste")
  contactsDestinataire MessageContact[]   @relation("ContactDestinatairePoste")
  projetsResponsable   Projet[]           @relation("ProjetResponsablePoste")

  @@map("postes")
}

model AffectationPoste {
  id                 String            @id @default(cuid())
  mandatId           String            @map("mandat_id")
  posteId            String            @map("poste_id")
  memberId           String            @map("member_id")
  statut             StatutAffectation @default(ACTIF)
  dateDebut          DateTime          @map("date_debut")
  dateFin            DateTime?         @map("date_fin")
  raisonInactivation String?           @map("raison_inactivation")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")
  mandat             Mandat            @relation(fields: [mandatId], references: [id])
  member             Member            @relation(fields: [memberId], references: [id])
  poste              Poste             @relation(fields: [posteId], references: [id])

  @@unique([mandatId, posteId, memberId])
  @@index([mandatId, statut])
  @@index([posteId, statut])
  @@map("affectations_poste")
}

model Content {
  id              String          @id @default(cuid())
  type            ContentType
  titre           String
  contenu         String?
  lienExterne     String?         @map("lien_externe")
  imagePrincipale String?         @map("image_principale")
  tags            String[]        @default([])
  visibiliteCible VisibiliteCible @map("visibilite_cible")
  statutWorkflow  StatutWorkflow  @default(BROUILLON) @map("statut_workflow")
  auteurPosteId   String          @map("auteur_poste_id")
  mandatId        String          @map("mandat_id")
  approvedById    String?         @map("approved_by_id")
  approvedAt      DateTime?       @map("approved_at")
  rejectionReason String?         @map("rejection_reason")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")
  facebookPostId  String?         @map("facebook_post_id")
  /** Images et PDF attachés (tableau JSON : [{ url, kind: IMAGE | DOCUMENT, label? }]) */
  attachments     Json?           @map("attachments")
  comments        Comment[]
  approvedBy      User?           @relation("ContentApprovedBy", fields: [approvedById], references: [id])
  auteurPoste     Poste           @relation("ContentAuteurPoste", fields: [auteurPosteId], references: [id])
  mandat          Mandat          @relation(fields: [mandatId], references: [id])

  @@index([mandatId, visibiliteCible, statutWorkflow])
  @@index([type, statutWorkflow])
  @@map("contents")
}

model Comment {
  id           String   @id @default(cuid())
  contentId    String   @map("content_id")
  auteurUserId String   @map("auteur_user_id")
  texte        String
  isDeleted    Boolean  @default(false) @map("is_deleted")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  auteur       User     @relation(fields: [auteurUserId], references: [id])
  content      Content  @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@index([contentId, createdAt])
  @@map("comments")
}

model Projet {
  id                 String          @id @default(cuid())
  titre              String
  slug               String          @unique
  objectif           String
  description        String
  actions            String?
  statut             ProjetStatut    @default(BROUILLON)
  visibiliteSite     Boolean         @default(false) @map("visibilite_site")
  responsablePosteId String          @map("responsable_poste_id")
  mandatId           String          @map("mandat_id")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  mandat             Mandat          @relation(fields: [mandatId], references: [id])
  responsablePoste   Poste           @relation("ProjetResponsablePoste", fields: [responsablePosteId], references: [id])
  medias             ProjetMedia[]
  partenaires        ProjetPartner[]

  @@index([mandatId, statut, visibiliteSite])
  @@map("projets")
}

model ProjetMedia {
  id        String          @id @default(cuid())
  projetId  String          @map("projet_id")
  type      ProjetMediaType
  url       String
  ordre     Int             @default(0)
  createdAt DateTime        @default(now()) @map("created_at")
  projet    Projet          @relation(fields: [projetId], references: [id], onDelete: Cascade)

  @@index([projetId, ordre])
  @@map("projets_media")
}

model Partner {
  id             String          @id @default(cuid())
  nom            String
  logo           String?
  description    String?
  siteUrl        String?         @map("site_url")
  type           String?
  statut         String          @default("ACTIF")
  visibiliteSite Boolean         @default(true) @map("visibilite_site")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  projets        ProjetPartner[]

  @@index([visibiliteSite])
  @@map("partners")
}

model ProjetPartner {
  projetId  String   @map("projet_id")
  partnerId String   @map("partner_id")
  createdAt DateTime @default(now()) @map("created_at")
  partner   Partner  @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  projet    Projet   @relation(fields: [projetId], references: [id], onDelete: Cascade)

  @@id([projetId, partnerId])
  @@map("projets_partners")
}

/// Contenu éditorial du site vitrine (accueil, sections statiques). Clé fixe `default` en seed.
model SitePublicPage {
  id        String   @id
  payload   Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_public_page")
}

model Event {
  id               String       @id @default(cuid())
  titre            String
  slug             String       @unique
  description      String
  dateDebut        DateTime     @map("date_debut")
  dateFin          DateTime?    @map("date_fin")
  lieu             String?
  statut           EventStatut  @default(A_VENIR)
  afficheSite      Boolean      @default(false) @map("affiche_site")
  createdByPosteId String       @map("created_by_poste_id")
  mandatId         String       @map("mandat_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")
  createdByPoste   Poste        @relation("EventCreatedByPoste", fields: [createdByPosteId], references: [id])
  mandat           Mandat       @relation(fields: [mandatId], references: [id])
  medias           EventMedia[]

  @@index([afficheSite, statut, dateDebut])
  @@map("events")
}

model EventMedia {
  id           String   @id @default(cuid())
  eventId      String   @map("event_id")
  url          String
  isPrincipale Boolean  @default(false) @map("is_principale")
  ordre        Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  event        Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, ordre])
  @@map("events_media")
}

model DemandeAdhesion {
  id            String        @id @default(cuid())
  prenom        String
  nom           String
  email         String
  telephone     String?
  ville         String?
  pays          String?
  message       String?
  statut        DemandeStatut @default(EN_ATTENTE)
  processedById String?       @map("processed_by_id")
  processedAt   DateTime?     @map("processed_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  processedBy   User?         @relation("DemandeAdhesionProcessedBy", fields: [processedById], references: [id])

  @@index([statut, createdAt])
  @@map("demandes_adhesion")
}

model DemandePartenariat {
  id              String        @id @default(cuid())
  organisation    String
  contactNom      String?       @map("contact_nom")
  email           String
  telephone       String?
  typePartenariat String?       @map("type_partenariat")
  message         String?
  statut          DemandeStatut @default(EN_ATTENTE)
  processedById   String?       @map("processed_by_id")
  processedAt     DateTime?     @map("processed_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")
  processedBy     User?         @relation("DemandePartenariatProcessedBy", fields: [processedById], references: [id])

  @@index([statut, createdAt])
  @@map("demandes_partenariat")
}

model DonationIntent {
  id               String               @id @default(cuid())
  type             DonationIntentType
  montantEstime    Decimal?             @map("montant_estime") @db.Decimal(18, 2)
  description      String?
  nom              String?
  email            String?
  telephone        String?
  statut           DonationIntentStatut @default(NOUVEAU)
  handledByPosteId String?              @map("handled_by_poste_id")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")
  handledByPoste   Poste?               @relation("DonationHandledByPoste", fields: [handledByPosteId], references: [id])

  @@index([statut, createdAt])
  @@map("donation_intents")
}

model MessageContact {
  id                  String        @id @default(cuid())
  nom                 String
  email               String
  sujet               String
  message             String
  statut              ContactStatut @default(NOUVEAU)
  destinatairePosteId String?       @map("destinataire_poste_id")
  assignedToPosteId   String?       @map("assigned_to_poste_id")
  createdAt           DateTime      @default(now()) @map("created_at")
  updatedAt           DateTime      @updatedAt @map("updated_at")
  assignedToPoste     Poste?        @relation("ContactAssignedToPoste", fields: [assignedToPosteId], references: [id])
  destinatairePoste   Poste?        @relation("ContactDestinatairePoste", fields: [destinatairePosteId], references: [id])

  @@index([statut, createdAt])
  @@map("messages_contact")
}

model BureauMessage {
  id           String                    @id @default(cuid())
  auteurUserId String                    @map("auteur_user_id")
  mandatId     String?                   @map("mandat_id")
  /// Salon général ou discussion 1:1 entre deux membres du bureau
  threadKind   BureauThreadKind          @default(SALON) @map("thread_kind")
  /// Message utilisateur ou annonce système (ex. lien visioconférence)
  messageKind  BureauMessageKind         @default(USER) @map("message_kind")
  /// Destinataire d’un message DIRECT (l’interlocuteur 1:1, pas l’auteur)
  dmPeerUserId String?                   @map("dm_peer_user_id")
  texte        String
  createdAt    DateTime                  @default(now()) @map("created_at")
  editedAt     DateTime?                 @map("edited_at")
  deletedAt    DateTime?                 @map("deleted_at")
  deletedBy    String?                   @map("deleted_by")
  attachments  BureauMessageAttachment[]
  auteur       User                      @relation(fields: [auteurUserId], references: [id])
  mandat       Mandat?                   @relation(fields: [mandatId], references: [id])
  dmPeer       User?                     @relation("BureauMessageDmPeer", fields: [dmPeerUserId], references: [id], onDelete: SetNull)
  deletedByUser User?                   @relation("BureauMessageDeletedBy", fields: [deletedBy], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([mandatId])
  @@index([mandatId, threadKind, createdAt])
  @@map("bureau_messages")
}

model BureauMessageAttachment {
  id        String        @id @default(cuid())
  messageId String        @map("message_id")
  url       String
  type      String
  fileName  String        @map("file_name")
  fileSize  Int           @map("file_size")
  mimeType  String        @map("mime_type")
  message   BureauMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@map("bureau_message_attachments")
}

model AuditLog {
  id         String      @id @default(cuid())
  userId     String?     @map("user_id")
  action     AuditAction
  entityType String      @map("entity_type")
  entityId   String      @map("entity_id")
  beforeData Json?       @map("before_data")
  afterData  Json?       @map("after_data")
  createdAt  DateTime    @default(now()) @map("created_at")
  /// Email de l’acteur conservé après suppression du compte utilisateur (traçabilité)
  actorEmail String?     @map("actor_email")
  user       User?       @relation(fields: [userId], references: [id])

  @@index([entityType, entityId, createdAt])
  @@index([actorEmail])
  @@map("audit_logs")
}

model PageView {
  id          String   @id @default(cuid())
  path        String
  method      String   @default("GET")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  referer     String?
  country     String?
  countryCode String?  @map("country_code")
  city        String?
  region      String?
  isp         String?
  isProxy     Boolean  @default(false) @map("is_proxy")
  sessionId   String?  @map("session_id")
  userId      String?  @map("user_id")
  statusCode  Int?     @map("status_code")
  createdAt   DateTime @default(now()) @map("created_at")
  user        User?    @relation(fields: [userId], references: [id])

  @@index([path, createdAt])
  @@index([userId, createdAt])
  @@index([ipAddress, createdAt])
  @@index([createdAt])
  @@map("page_views")
}

model PresidentCitation {
  id          String    @id @default(cuid())
  nom         String
  message     String
  debutMandat DateTime  @map("debut_mandat")
  finMandat   DateTime? @map("fin_mandat")
  photoUrl    String?   @map("photo_url")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at")

  @@map("president_citations")
}

enum RoleSysteme {
  SUPER_ADMIN
  ADMIN
  MEMBER
}

enum StatutMembre {
  ACTIF
  SUSPENDU
  RADIE
  INACTIF
}

/// Genre déclaré (optionnel)
enum GenreMembre {
  FEMME
  HOMME
  AUTRE
  NE_PAS_DIRE
}

enum StatutMandat {
  ACTIF
  EXPIRE
  ARCHIVE
}

enum StatutAffectation {
  ACTIF
  INACTIF
  ARCHIVE
}

enum ContentType {
  ACTIVITE
  ACTUALITE
  PARTAGE
  ANNONCE
}

enum VisibiliteCible {
  PRIVE_BUREAU
  PUBLIC_SITE
}

enum StatutWorkflow {
  BROUILLON
  SOUMIS
  APPROUVE
  REJETE
  PUBLIE
  ARCHIVE
}

enum ProjetStatut {
  BROUILLON
  EN_COURS
  TERMINE
  SUSPENDU
  ANNULE
}

enum ProjetMediaType {
  IMAGE
  DOCUMENT
}

enum EventStatut {
  PASSE
  EN_COURS
  A_VENIR
}

enum DemandeStatut {
  EN_ATTENTE
  APPROUVEE
  REFUSEE
}

enum DonationIntentType {
  FINANCIER
  MATERIEL
  AUTRE
}

enum DonationIntentStatut {
  NOUVEAU
  CONTACTE
  CONFIRME
  CLASSE_SANS_SUITE
}

enum ContactStatut {
  NOUVEAU
  EN_COURS
  TRAITE
  ARCHIVE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  APPROVE
  REJECT
  SUBMIT
  ASSIGN
  INACTIVATE
  ARCHIVE
}

enum BureauThreadKind {
  SALON
  DIRECT
}

enum BureauMessageKind {
  USER
  SYSTEM
}
